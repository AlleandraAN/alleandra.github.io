theme: jekyll-theme-minimal
title: Alleandra Asyrafian Nursani

# We inject the CSS directly into the page head using Jekyll
inline_css: >
  html, body {
    margin: 0; padding: 0;
    width: 100%; height: 100vh;
    overflow: hidden;
    font-family: sans-serif;
  }
  .dashboard-container {
    display: flex;
    width: 100%; height: 100vh;
  }
  .about-panel {
    flex: 1;
    padding: 40px;
    border-right: 1px solid #e5e5ea; /* The vertical line */
  }
  .right-panels {
    flex: 2;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .work-panel {
    flex: 1;
    padding: 40px;
    border-bottom: 1px solid #e5e5ea; /* The horizontal line */
  }
  .projects-panel {
    flex: 1;
    padding: 40px;
  }
